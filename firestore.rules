rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwnerFieldValid() {
      return request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if ownsUserDoc(userId);
      allow delete: if false;
    }

    match /publications/{publicationId} {
      allow read: if resource.data.status == 'published'
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if signedIn() && isOwnerFieldValid();
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /meta_connections/{connectionId} {
      allow read, write: if false;
    }

    match /meta_oauth_states/{stateId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
