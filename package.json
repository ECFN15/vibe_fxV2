{
  "name": "vibe_fxv2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "verify:local": "npm run lint && npm run test:scope && npm run audit:secrets && npm run test:publication-flow && npm run test:account-deletion && npm run test:billing-products && npm run test:billing-ledger && npm run test:ai-gateway && npm run test:ai-ledger && npm run test:app-check && npm run build && npm run functions:lint && npm run audit:deps",
    "verify:routes": "npm run test:routes",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "audit:deps": "npm audit --omit=optional",
    "check:e2e-readiness": "node scripts/check-e2e-readiness.mjs",
    "check:deploy-target": "node scripts/check-deploy-target.mjs",
    "check:emulator-readiness": "node scripts/check-emulator-readiness.mjs",
    "check:pixabay-provider": "node scripts/check-pixabay-provider.mjs",
    "import:pixabay-ai": "node scripts/import-pixabay-ai-music.mjs",
    "emulators": "firebase emulators:start --only auth,firestore,storage,functions",
    "test:emulators": "firebase emulators:exec --project demo-vibefx --only auth,firestore,storage \"node --no-warnings scripts/smoke-firebase-emulators.mjs\"",
    "test:studio-emulators": "firebase emulators:exec --project demo-vibefx --only auth,firestore,storage \"node --no-warnings scripts/smoke-studio-emulator-ui.mjs\"",
    "lint": "eslint",
    "test:scope": "node scripts/audit-scope.mjs",
    "test:account-deletion": "node scripts/smoke-account-deletion.mjs",
    "test:billing-products": "node scripts/smoke-billing-products.mjs",
    "test:billing-ledger": "node scripts/smoke-billing-ledger.mjs",
    "test:ai-gateway": "node scripts/smoke-ai-gateway.mjs",
    "test:ai-ledger": "node scripts/smoke-ai-ledger.mjs",
    "test:app-check": "node scripts/smoke-app-check.mjs",
    "test:publication-flow": "node --no-warnings scripts/smoke-publication-flow.mjs",
    "test:routes": "node scripts/smoke-routes.mjs",
    "test:studio-ui": "playwright test scripts/smoke-studio-ui.spec.cjs scripts/smoke-studio-ai-rail.spec.cjs scripts/smoke-soundtrack-ui.spec.cjs --reporter=line --workers=1",
    "test:soundtrack-core": "node scripts/smoke-soundtrack-core.mjs",
    "test:soundtrack-ui": "npm run test:soundtrack-core && playwright test scripts/smoke-soundtrack-ui.spec.cjs --reporter=line --workers=1",
    "test:vision-ui": "node scripts/audit-vision-filters.mjs && node scripts/run-vision-ui-test.mjs",
    "check:vision-corpus": "node scripts/check-vision-corpus.mjs",
    "test:vision-corpus": "node scripts/check-vision-corpus.mjs && node scripts/run-vision-corpus-test.mjs",
    "test:video-ui": "node scripts/smoke-video-timeline-model.mjs && node scripts/smoke-video-store.mjs && node scripts/run-video-ui-test.mjs",
    "functions:lint": "npm --prefix functions run lint",
    "firebase:deploy:backend": "node scripts/firebase-deploy.mjs backend",
    "firebase:deploy:functions": "node scripts/firebase-deploy.mjs functions"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "firebase": "^12.13.0",
    "howler": "^2.2.4",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "firebase-tools": "^15.3.1"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
