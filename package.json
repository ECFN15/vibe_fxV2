{
  "name": "vibe_fxv2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "verify:local": "npm run lint && npm run test:scope && npm run audit:secrets && npm run test:publication-flow && npm run build && npm run functions:lint && npm run audit:deps",
    "verify:routes": "npm run test:routes",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "audit:deps": "npm audit --omit=optional",
    "check:e2e-readiness": "node scripts/check-e2e-readiness.mjs",
    "check:deploy-target": "node scripts/check-deploy-target.mjs",
    "check:emulator-readiness": "node scripts/check-emulator-readiness.mjs",
    "emulators": "firebase emulators:start --only auth,firestore,storage,functions",
    "test:emulators": "firebase emulators:exec --project demo-vibefx --only auth,firestore,storage \"node --no-warnings scripts/smoke-firebase-emulators.mjs\"",
    "test:studio-emulators": "firebase emulators:exec --project demo-vibefx --only auth,firestore,storage \"node --no-warnings scripts/smoke-studio-emulator-ui.mjs\"",
    "lint": "eslint",
    "test:scope": "node scripts/audit-scope.mjs",
    "test:publication-flow": "node --no-warnings scripts/smoke-publication-flow.mjs",
    "test:routes": "node scripts/smoke-routes.mjs",
    "test:studio-ui": "playwright test scripts/smoke-studio-ui.spec.cjs --reporter=line",
    "functions:lint": "npm --prefix functions run lint",
    "firebase:deploy:backend": "node scripts/firebase-deploy.mjs backend",
    "firebase:deploy:functions": "node scripts/firebase-deploy.mjs functions"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "firebase": "^12.13.0",
    "howler": "^2.2.4",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "firebase-tools": "^15.3.1"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
