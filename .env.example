NEXT_PUBLIC_SITE_URL=https://vibefx.app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west9
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Server-only music provider connectors
JAMENDO_CLIENT_ID=
FREESOUND_API_KEY=
MINIMAX_API_KEY=
MINIMAX_MUSIC_MODEL=music-2.6-free
MUREKA_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
LOUDLY_API_KEY=
MUBERT_CUSTOMER_ID=
MUBERT_ACCESS_TOKEN=
SOUNDRAW_API_KEY=
BEATOVEN_API_KEY=
ADMIN_EMAILS=
ENFORCE_META_APP_CHECK=true
ENFORCE_BILLING_APP_CHECK=true
ENFORCE_AI_APP_CHECK=true
ENFORCE_ACCOUNT_APP_CHECK=true
ENFORCE_EXPORT_APP_CHECK=true
APP_BASE_URL=https://vibefx.app
META_GRAPH_VERSION=v24.0
STRIPE_PRICE_PREMIUM_LIFETIME=
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1200=
STRIPE_PRICE_CREDITS_3200=
STRIPE_PRICE_CREDITS_7000=
VIBEFX_ENABLE_MIDJOURNEY_LIBRARY=false
VIBEFX_ALLOW_UNSAFE_MIDJOURNEY_LIBRARY_IN_PROD=false
VIBEFX_ENABLE_MOCK_AI_GATEWAY=false
NEXT_PUBLIC_VIBECUT_EXPORT_MODE=localMock
GOOGLE_CLOUD_PROJECT=
EXPORT_RENDERER_URL=
EXPORT_SIGNING_SECRET=

# Local emulator example values:
# NEXT_PUBLIC_FIREBASE_API_KEY=demo-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-vibefx.localhost
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-vibefx
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-vibefx.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo
# NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# Firebase Functions secrets:
# firebase functions:secrets:set META_APP_ID
# firebase functions:secrets:set META_APP_SECRET
# firebase functions:secrets:set META_OAUTH_REDIRECT_URI
# firebase functions:secrets:set META_TOKEN_ENCRYPTION_KEY
# Production callables enforce App Check by default. Use `false` only in a local
# emulator session if needed; never deploy payment/AI/Meta callables without it.
# ENFORCE_META_APP_CHECK=false
# ENFORCE_BILLING_APP_CHECK=false
# ENFORCE_AI_APP_CHECK=false
# ENFORCE_ACCOUNT_APP_CHECK=false
# ENFORCE_EXPORT_APP_CHECK=false
# Stripe Checkout one-time products:
# firebase functions:secrets:set STRIPE_SECRET_KEY
# firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# APP_BASE_URL=https://your-production-domain.example
# STRIPE_PRICE_PREMIUM_LIFETIME=price_... # one-time 9.99 EUR lifetime access
# STRIPE_PRICE_CREDITS_500=price_...
# STRIPE_PRICE_CREDITS_1200=price_...
# STRIPE_PRICE_CREDITS_3200=price_...
# STRIPE_PRICE_CREDITS_7000=price_...
# Local-only legacy library. Keep disabled in production SaaS unless an admin-only
# migration session explicitly accepts the unsafe Midjourney scraper/proxy risk.
# VIBEFX_ENABLE_MIDJOURNEY_LIBRARY=true
# VIBEFX_ALLOW_UNSAFE_MIDJOURNEY_LIBRARY_IN_PROD=false
# Local/emulator only: enable mock AI policies for credit gateway tests.
# Keep false in production; real providers require aiPricingPolicies + trusted registry.
# VIBEFX_ENABLE_MOCK_AI_GATEWAY=true
# Vibe_CUT Export Pro local-first. Keep localMock until Firebase/Cloud Run are configured.
# NEXT_PUBLIC_VIBECUT_EXPORT_MODE=localMock
# NEXT_PUBLIC_VIBECUT_EXPORT_MODE=firebase
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project
# EXPORT_RENDERER_URL=https://your-render-service.run.app
# firebase functions:secrets:set EXPORT_SIGNING_SECRET
# Cloud Run render-service also needs EXPORT_SIGNING_SECRET with the same value.
# Optional manual fallback:
# firebase functions:secrets:set META_ACCESS_TOKEN
# firebase functions:secrets:set META_IG_USER_ID
# firebase functions:secrets:set META_FACEBOOK_PAGE_ID
